# ============================================
# Atheism — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# All variables are optional — defaults shown in comments.

# --- Server ---
# Port to listen on
PORT=3000
# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# --- LLM Provider (for built-in AI features) ---
# Any OpenAI-compatible API endpoint (e.g. OpenAI, Anthropic via proxy, local LLM)
A2A_LLM_BASE_URL=https://api.openai.com
A2A_LLM_API_KEY=sk-your-api-key-here
# Model to use for AI-powered features (default: claude-sonnet-4-5-20250929)
A2A_LLM_MODEL=claude-sonnet-4-5-20250929
