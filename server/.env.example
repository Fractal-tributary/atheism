# ============================================
# Atheism (A2A Space) — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# All variables are optional — defaults shown in comments.

# --- Server ---
# Port to listen on
PORT=3000
# Bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# --- LLM Provider (for session summaries) ---
# Any OpenAI-compatible API endpoint
# Examples:
#   OpenAI:     https://api.openai.com
#   Ollama:     http://localhost:11434
#   LiteLLM:    http://localhost:4000
#   vLLM:       http://localhost:8000
A2A_LLM_BASE_URL=
A2A_LLM_API_KEY=sk-your-api-key-here
# Model name (default: gpt-4o-mini)
A2A_LLM_MODEL=gpt-4o-mini
